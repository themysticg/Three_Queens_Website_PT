{
  "name": "fivem-whitelist-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && node scripts/migrate-if-postgres.js && next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:seed": "npx prisma db seed",
    "postinstall": "prisma generate",
    "deploy": "vercel --prod",
    "discord:presence": "tsx scripts/discord-presence-bot.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "discord.js": "^14.19.3",
    "dotenv": "^17.3.1",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
